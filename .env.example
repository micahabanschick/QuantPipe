# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Data providers
EODHD_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Crypto exchanges (read + trade only — NO withdrawal permission)
KRAKEN_API_KEY=
KRAKEN_SECRET=
COINBASE_API_KEY=
COINBASE_SECRET=

# Interactive Brokers Gateway
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# Alerting (pick one or both)
PUSHOVER_TOKEN=
PUSHOVER_USER=
NTFY_TOPIC=

# Backblaze B2 backup (free tier: 10 GB)
# Create at backblaze.com → Buckets → App Keys
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET=quantpipe-backup

# HashiCorp Vault (production server only — leave blank for local dev)
# Set these after running deploy/vault/init_secrets.sh on the server
VAULT_ADDR=
VAULT_TOKEN=
