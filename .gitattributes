# Force LF line endings for shell scripts and configs on all platforms
*.sh        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.hcl       text eol=lf
*.conf      text eol=lf
*.toml      text eol=lf
*.py        text eol=lf
*.md        text eol=lf
Makefile    text eol=lf

# Windows-native files keep CRLF
*.bat       text eol=crlf
*.ps1       text eol=crlf
