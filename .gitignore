# Data (never commit raw market data)
data/
*.parquet
*.arrow
# But always track test snapshot fixtures
!tests/fixtures/*.parquet

# Logs
logs/
*.log

# Environment
.env
.env.*
*.env
secrets.toml
# But always track the example template
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
dist/
build/
*.egg

# uv
.uv/
uv.lock

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
!.vscode/settings.json
.idea/
*.swp
*.swo

# Claude Code
.claude/

# OS
.DS_Store
Thumbs.db

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Secrets / keys (extra safety)
*_key.txt
*_secret.txt
credentials*.json

# Local runbooks and private notes (machine-specific, never commit)
*.local.md

# Pipeline runtime files (generated, not source)
.pipeline_heartbeat.json

# Local planning and backlog documents
FEATURE_BACKLOG.md
MOBILE_SETUP.md
